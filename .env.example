# Copy to `.env` and fill in values for local development.
# SvelteKit only exposes variables prefixed with PUBLIC_ to the frontend.

# Addon Manager backend (no trailing slash).
# Used for version checks, addon downloads, and server ping.
#
# Examples:
#   PUBLIC_SERVER_HOST=https://nhfmanager.sragia.com
#   PUBLIC_SERVER_HOST=http://localhost:5000
PUBLIC_SERVER_HOST=https://your-addon-manager-host.example.com

# External API backend for the Companion tab (no trailing slash).
# Used for /api/external/v1/* (seasons, rosters, assignment-notes).
# This is typically your NHF web app / raid tools host, not the addon manager host.
#
# Examples:
#   PUBLIC_EXTERNAL_API_HOST=https://your-nhf-app.example.com
#   PUBLIC_EXTERNAL_API_HOST=http://localhost:5000
PUBLIC_EXTERNAL_API_HOST=https://your-external-api-host.example.com

# --- Optional: only needed to build signed app updates (CI / release builds) ---

# Tauri updater signing key (base64-encoded private key from `tauri signer generate`).
# TAURI_SIGNING_PRIVATE_KEY=

# Password for the signing key, if one was set during key generation.
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
